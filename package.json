{
  "name": "axiom",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "db:push": "drizzle-kit push",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx src/shared/lib/db/seed.ts",
    "contracts:install": "npm --prefix contracts install",
    "contracts:compile": "npm --prefix contracts run compile",
    "contracts:test": "npm --prefix contracts run test",
    "contracts:deploy:testnet": "npm --prefix contracts run deploy:testnet"
  },
  "dependencies": {
    "@web3-storage/w3up-client": "^17.3.0",
    "@hashgraph/sdk": "^2.80.0",
    "@lit-protocol/auth-helpers": "^8.2.1",
    "@lit-protocol/constants": "^9.0.1",
    "@lit-protocol/lit-node-client": "^7.4.0",
    "@neondatabase/serverless": "^1.0.2",
    "@tailwindcss/postcss": "^4.1.18",
    "better-sqlite3": "^12.6.2",
    "drizzle-orm": "^0.45.1",
    "drizzle-zod": "^0.8.3",
    "lucide-react": "^0.575.0",
    "next": "^15.5.12",
    "react": "19.1.1",
    "react-dom": "19.1.1",
    "react-pdf": "^10.4.1",
    "thirdweb": "^5",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "19.1.10",
    "@types/react-dom": "19.1.7",
    "autoprefixer": "^10.0.1",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.9",
    "eslint": "^4.1.1",
    "eslint-config-next": "^0.2.4",
    "postcss": "^8",
    "prettier": "^3.6.2",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "^5"
  },
  "pnpm": {
    "overrides": {
      "@types/react": "19.1.10",
      "@types/react-dom": "19.1.7"
    }
  }
}
